{
  "compilerOptions": {
    "rootDir": "src",
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitOverride": true
  },
  "include": [
    "src/**/*"
  ],
  "tsc-alias": {
    "resolveFullPaths": true
  }
}