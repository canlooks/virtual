{
  "name": "@canlooks/virtual",
  "version": "1.2.2",
  "author": "C.CanLiang <canlooks@gmail.com>",
  "description": "My ui framework",
  "license": "MIT",
  "keywords": [
    "react",
    "virual",
    "list",
    "grid",
    "table"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://gitee.com/canlooks/c_virtual",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/canlooks/c_virtual"
  },
  "bugs": {
    "url": "https://gitee.com/canlooks/c_virtual/issues",
    "email": "canlooks@gmail.com"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./grouped": {
      "types": "./dist/esm/grouped.d.ts",
      "import": "./dist/esm/grouped.js",
      "require": "./dist/cjs/grouped.js"
    },
    "./list": {
      "types": "./dist/esm/list.d.ts",
      "import": "./dist/esm/list.js",
      "require": "./dist/cjs/list.js"
    },
    "./table": {
      "types": "./dist/esm/table.d.ts",
      "import": "./dist/esm/table.js",
      "require": "./dist/cjs/table.js"
    }
  },
  "scripts": {
    "clean": "npx shx rm -rf dist",
    "build": "tsc -m esnext --outDir dist/esm & tsc -m commonjs --outDir dist/cjs",
    "build:alias": "tsc-alias --outDir dist/esm",
    "rebuild": "npm run clean && npm run build && npm run build:alias",
    "test:browser": "vite -c test/vite.config.mts",
    "test:unit": "npx ts-node test/unit.ts",
    "test:build": "vite build -c test/vite.config.mts"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
